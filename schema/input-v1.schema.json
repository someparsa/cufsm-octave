{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://someparsa.github.io/cufsm-octave/schema/input-v1.schema.json",
  "title": "CUFSM Octave CLI Input",
  "type": "object",
  "required": ["version", "model", "analysis"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "units": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "system": { "type": "string" }
      }
    },
    "model": {
      "type": "object",
      "required": ["materials", "nodes", "elements"],
      "additionalProperties": false,
      "properties": {
        "materials": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/material" }
        },
        "nodes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/node" }
        },
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/element" }
        },
        "springs": {
          "type": "array",
          "items": { "$ref": "#/$defs/spring" },
          "default": []
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" },
          "default": []
        }
      }
    },
    "loading": {
      "oneOf": [
        { "$ref": "#/$defs/stressTableLoading" },
        { "$ref": "#/$defs/generatedActionLoading" }
      ]
    },
    "analysis": {
      "type": "object",
      "required": ["type", "boundary_condition", "lengths"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "signature_curve"
        },
        "boundary_condition": {
          "type": "string",
          "enum": ["S-S", "C-C", "S-C", "C-F", "C-G"]
        },
        "lengths": {
          "oneOf": [
            { "$ref": "#/$defs/generatedLengths" },
            { "$ref": "#/$defs/explicitLengths" }
          ]
        },
        "longitudinal_terms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "integer", "minimum": 1 }
            },
            "per_length": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["terms"],
                "additionalProperties": false,
                "properties": {
                  "terms": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          }
        },
        "eigenmodes": {
          "type": "integer",
          "minimum": 1,
          "default": 20
        },
        "vectorized": {
          "type": "boolean",
          "default": false
        },
        "mesh_refinement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "doubler": { "type": "boolean", "default": false }
          }
        },
        "cfsm": { "$ref": "#/$defs/cfsm" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "text_path": { "type": "string" }
      }
    }
  },
  "$defs": {
    "material": {
      "type": "object",
      "required": ["id", "Ex", "Ey", "nu_x", "nu_y", "G"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer" },
        "Ex": { "type": "number" },
        "Ey": { "type": "number" },
        "nu_x": { "type": "number" },
        "nu_y": { "type": "number" },
        "G": { "type": "number" }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "x", "z", "dof_x", "dof_z", "dof_y", "dof_rotation", "stress"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "x": { "type": "number" },
        "z": { "type": "number" },
        "dof_x": { "type": "integer", "enum": [0, 1] },
        "dof_z": { "type": "integer", "enum": [0, 1] },
        "dof_y": { "type": "integer", "enum": [0, 1] },
        "dof_rotation": { "type": "integer", "enum": [0, 1] },
        "stress": { "type": "number" }
      }
    },
    "element": {
      "type": "object",
      "required": ["id", "node_i", "node_j", "thickness", "material_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "node_i": { "type": "integer", "minimum": 1 },
        "node_j": { "type": "integer", "minimum": 1 },
        "thickness": { "type": "number", "exclusiveMinimum": 0 },
        "material_id": { "type": "integer" }
      }
    },
    "spring": {
      "type": "object",
      "required": ["node", "dof", "stiffness", "kflag"],
      "additionalProperties": false,
      "properties": {
        "node": { "type": "integer", "minimum": 1 },
        "dof": { "type": "integer", "enum": [1, 2, 3, 4] },
        "stiffness": { "type": "number" },
        "kflag": { "type": "integer", "enum": [0, 1] }
      }
    },
    "constraint": {
      "type": "object",
      "required": ["node_e", "dof_e", "coefficient", "node_k", "dof_k"],
      "additionalProperties": false,
      "properties": {
        "node_e": { "type": "integer", "minimum": 1 },
        "dof_e": { "type": "integer", "enum": [1, 2, 3, 4] },
        "coefficient": { "type": "number" },
        "node_k": { "type": "integer", "minimum": 1 },
        "dof_k": { "type": "integer", "enum": [1, 2, 3, 4] }
      }
    },
    "stressTableLoading": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "stress_table" }
      }
    },
    "generatedActionLoading": {
      "type": "object",
      "required": ["type", "fy", "actions"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "generated_from_actions" },
        "fy": { "type": "number", "exclusiveMinimum": 0 },
        "unsymmetric": { "type": "boolean", "default": false },
        "actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "P": { "type": "number" },
            "Mxx": { "type": "number" },
            "Mzz": { "type": "number" },
            "M11": { "type": "number" },
            "M22": { "type": "number" },
            "P_factor": { "type": "number" },
            "Mxx_factor": { "type": "number" },
            "Mzz_factor": { "type": "number" },
            "M11_factor": { "type": "number" },
            "M22_factor": { "type": "number" }
          }
        }
      }
    },
    "generatedLengths": {
      "type": "object",
      "required": ["type", "min", "max", "count"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["logspace", "linspace"] },
        "min": { "type": "number", "exclusiveMinimum": 0 },
        "max": { "type": "number", "exclusiveMinimum": 0 },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "explicitLengths": {
      "type": "object",
      "required": ["type", "values"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "explicit" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "cfsm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ospace": { "type": "integer", "enum": [1, 2, 3, 4] },
        "couple": { "type": "integer", "enum": [1, 2] },
        "orth": { "type": "integer", "enum": [1, 2, 3] },
        "norm": { "type": "integer", "enum": [0, 1, 2, 3] },
        "local": { "$ref": "#/$defs/modeSelection" },
        "distortional": { "$ref": "#/$defs/modeSelection" },
        "global": { "$ref": "#/$defs/modeSelection" },
        "other": { "$ref": "#/$defs/modeSelection" }
      }
    },
    "modeSelection": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    }
  }
}
